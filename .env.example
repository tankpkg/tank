# Database (Drizzle ORM via Supabase Pooler)
# Replace with your Supabase pooler connection string
DATABASE_URL=<your-postgresql-connection-string>

# Supabase (Storage only — we use better-auth for authentication)
SUPABASE_URL=<your-supabase-project-url>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Auth (GitHub OAuth — create at https://github.com/settings/developers)
# 1. Go to https://github.com/settings/developers
# 2. Create a new OAuth App
# 3. Set Authorization callback URL to: http://localhost:3000/api/auth/callback/github
# 4. Copy the Client ID and Client Secret here
GITHUB_CLIENT_ID=<your-github-client-id>
GITHUB_CLIENT_SECRET=<your-github-client-secret>
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>

# First admin - the email of the first user to be promoted to admin
# After your first login, run: pnpm admin:bootstrap
FIRST_ADMIN_EMAIL=<your-email@example.com>

# App (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# TanStack Start app (`apps/web-tanstack`) local URLs
APP_URL=http://localhost:3001
BETTER_AUTH_URL=http://localhost:3001
AUTH_PROVIDERS=github,credentials

# Storage backend used by alternate web apps
# STORAGE_BACKEND=supabase
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=packages
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_ENDPOINT=

# Session storage
SESSION_STORE=memory
REDIS_URL=

# Analytics
# Google Analytics 4 measurement ID (starts with G-)
NEXT_PUBLIC_GA_ID=<your-ga4-measurement-id>

# PostHog product analytics (free: 1M events + 5K recordings/month)
# Sign up at https://posthog.com — no credit card required
NEXT_PUBLIC_POSTHOG_KEY=<your-posthog-project-api-key>
NEXT_PUBLIC_POSTHOG_HOST=<your-posthog-host>

# ============================================
# LLM Security Analysis Configuration (Optional)
# ============================================
# Enable LLM-assisted security scanning to reduce false positives.
# Without LLM keys, the scanner uses regex-only mode (still effective).

# Master switch: "true", "false", or "auto" (default)
# "auto" = enabled if any LLM_* vars are configured
# LLM_SCAN_ENABLED=auto

# --- Option A: Custom provider (BYOLLM) ---
# Use ANY OpenAI-compatible provider (OpenAI, Gemini, Claude via OpenRouter, etc.)
# LLM_API_KEY=sk-your-key-here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# --- Option B: Built-in free providers ---
# Groq (free, fast, recommended): https://console.groq.com
# GROQ_API_KEY=gsk_xxxxxxxxxxxx

# OpenRouter (free fallback): https://openrouter.ai
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxx

# --- Optional tuning ---
# LLM_SCAN_TIMEOUT_MS=8000          # Max wait per LLM call (default: 8000)
# LLM_SCAN_MAX_SNIPPETS=12          # Max findings per LLM call (default: 12)
# LLM_SCAN_TEMPERATURE=0.0          # Deterministic output (default: 0.0)

# --- Advanced: Custom model selection ---
# Override default models for built-in providers (rarely needed)
# GROQ_8B_MODEL=llama-3.1-8b-instant
# GROQ_70B_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
