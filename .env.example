# ── Core ──
APP_URL=http://localhost:3001
# APP_NAME=Tank

# ── Database (required) ──
DATABASE_URL=<your-postgresql-connection-string>

# ── Auth (required) ──
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=<generate-with-openssl-rand-base64-32>
# BETTER_AUTH_URL=http://localhost:3001
AUTH_PROVIDERS=github,credentials

# ── GitHub OAuth ──
# Create at https://github.com/settings/developers
# Callback URL: http://localhost:3001/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── OIDC SSO (optional — enterprise only) ──
# OIDC_PROVIDER_ID=enterprise-oidc
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_DISCOVERY_URL=

# ── Storage ──
# STORAGE_BACKEND=supabase
SUPABASE_URL=<your-supabase-project-url>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=packages
# S3_REGION=us-east-1

# ── Session ──
SESSION_STORE=memory
# REDIS_URL=redis://localhost:6379

# ── Email (optional — needed for credentials auth) ──
# RESEND_API_KEY=
# EMAIL_FROM=noreply@tank.example.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# ── External Services ──
# PYTHON_API_URL=http://localhost:8000
# LOKI_URL=http://localhost:3100

# ── Admin ──
FIRST_ADMIN_EMAIL=<your-email@example.com>
