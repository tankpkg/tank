{
  "$schema": "https://biomejs.dev/schemas/latest/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "packages/**",
      "apps/**",
      "scripts/**",
      "e2e/**",
      "bdd/**",
      "*.json",
      "*.jsonc",
      "*.js",
      "*.ts",
      "!**/node_modules",
      "!**/dist",
      "!**/build",
      "!**/.next",
      "!**/.output",
      "!**/.turbo",
      "!**/coverage",
      "!**/.source",
      "!**/.astro",
      "!**/.features-gen",
      "!**/generated",
      "!**/test-results",
      "!e2e/bdd/e2e/bdd/reports/report.html",
      "!**/next-env.d.ts",
      "!**/routeTree.gen.ts",
      "!**/.tanstack",
      "!**/auth-schema.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120,
    "lineEnding": "lf"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noUselessStringConcat": "error",
        "noUselessEmptyExport": "error",
        "noForEach": "warn"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn",
        "noUnusedImports": "error",
        "useHookAtTopLevel": "error"
      },
      "performance": {
        "noImgElement": "warn"
      },
      "security": {},
      "suspicious": {
        "noConsole": "warn",
        "noFocusedTests": "error",
        "noSkippedTests": "warn",
        "noExplicitAny": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "noParameterAssign": "error",
        "useAsConstAssertion": "error",
        "useDefaultParameterLast": "error",
        "useEnumInitializers": "error",
        "useSelfClosingElements": "error",
        "useSingleVarDeclarator": "error",
        "useNumberNamespace": "error",
        "noInferrableTypes": "error",
        "noUselessElse": "error",
        "noCommonJs": "error",
        "noEnum": "error",
        "noYodaExpression": "error",
        "useCollapsedElseIf": "error",
        "useConst": "error",
        "useTrimStartEnd": "error",
        "useTemplate": "warn",
        "useImportType": "error",
        "useShorthandAssign": "error",
        "useExponentiationOperator": "error",
        "useFragmentSyntax": "error"
      }
    }
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "bracketSameLine": true,
      "bracketSpacing": true,
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "allowWrongLineComments": true,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": true
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.astro"],
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    },
    {
      "includes": ["packages/cli/**", "scripts/**"],
      "linter": {
        "rules": {
          "suspicious": {
            "noConsole": "off"
          }
        }
      }
    }
  ]
}
