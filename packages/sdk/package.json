{
  "name": "@tankpkg/sdk",
  "version": "0.15.7",
  "description": "Official TypeScript SDK for the Tank registry — search, download, install, and audit AI agent skills programmatically",
  "type": "module",
  "homepage": "https://github.com/tankpkg/tank",
  "repository": {
    "type": "git",
    "url": "https://github.com/tankpkg/tank.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/tankpkg/tank/issues"
  },
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@internals/helpers": "workspace:*",
    "tar": "^7.5.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@internals/schemas": "workspace:*",
    "@types/node": "^25.5.0",
    "@types/tar": "^7.0.87",
    "tsdown": "^0.21.3",
    "vitest": "^4"
  },
  "peerDependencies": {
    "@internals/schemas": "workspace:*"
  },
  "peerDependenciesMeta": {
    "@internals/schemas": {
      "optional": true
    }
  }
}
