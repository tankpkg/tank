{
  "name": "@tankpkg/mcp-server",
  "version": "0.8.1",
  "description": "MCP server for Tank - scan and publish AI agent skills from your editor",
  "type": "module",
  "bin": {
    "tank-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsx --watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@internals/helpers": "workspace:*",
    "@internals/schemas": "workspace:*",
    "@types/node": "^25.5.0",
    "tsdown": "^0.21.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "ignore": "^7.0.5",
    "semver": "^7.7.4",
    "tar": "^7.5.11",
    "zod": "^4.3.6"
  },
  "keywords": [
    "mcp",
    "tank",
    "ai",
    "skills",
    "claude",
    "cursor",
    "copilot"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/tankpkg/tank.git",
    "directory": "packages/mcp-server"
  },
  "license": "MIT"
}
