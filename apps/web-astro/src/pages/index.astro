---
import Footer from '~/components/Footer.astro';
import Header from '~/components/Header.astro';
import CliQuickStart from '~/components/homepage/CliQuickStart.astro';
import CodeExample from '~/components/homepage/CodeExample.astro';
import CtaBanner from '~/components/homepage/CtaBanner.astro';
import Faq from '~/components/homepage/Faq.astro';
import FeatureGrid from '~/components/homepage/FeatureGrid.astro';
import Hero from '~/components/homepage/Hero.astro';
import Stats from '~/components/homepage/Stats.astro';
import WhyTank from '~/components/homepage/WhyTank.astro';
import { faqItems } from '~/consts';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { getPublicSkillCount } from '~/lib/data';
import { getStarCount } from '~/lib/github';

const skillCount = await getPublicSkillCount();

const starCount = await getStarCount();

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      name: 'Tank',
      url: 'https://tankpkg.dev',
      logo: 'https://tankpkg.dev/logo.png',
      description:
        'Security-first package registry for AI agent skills. Prevent credential exfiltration and supply chain attacks with mandatory security scanning.',
      sameAs: ['https://github.com/tankpkg', 'https://x.com/tankpkg']
    },
    {
      '@type': 'WebSite',
      name: 'Tank',
      url: 'https://tankpkg.dev',
      potentialAction: {
        '@type': 'SearchAction',
        target: 'https://tankpkg.dev/skills?q={search_term_string}',
        'query-input': 'required name=search_term_string'
      }
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqItems.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer
        }
      }))
    }
  ]
});
---

<BaseLayout title="Tank — Security-first package manager for AI agent skills" jsonLd={jsonLd}>
  <div class="min-h-screen bg-background tank-gradient-bg tank-grid-overlay">
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
      <div class="tank-orb tank-orb-green w-150 h-150 -top-48 -left-48 opacity-30"></div>
      <div class="tank-orb tank-orb-green w-125 h-125 top-1/3 -right-32 opacity-20"></div>
      <div class="tank-orb tank-orb-green w-100 h-100 bottom-0 left-1/4 opacity-25"></div>
    </div>
    <Header starCount={starCount} />
    <main class="relative">
      <Hero skillCount={skillCount} starCount={starCount} />
      <Stats skillCount={skillCount} />
      <CodeExample />
      <FeatureGrid />
      <CliQuickStart />
      <WhyTank />
      <Faq />
      <CtaBanner starCount={starCount} />
    </main>
    <Footer starCount={starCount} />
  </div>
</BaseLayout>

<style>
  .tank-gradient-bg {
    background:
      radial-gradient(ellipse 80% 50% at 20% 40%, rgba(0, 212, 255, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 80% 20%, rgba(139, 92, 246, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse 50% 30% at 50% 80%, rgba(0, 255, 136, 0.05) 0%, transparent 50%),
      linear-gradient(180deg, var(--tank-midnight) 0%, var(--tank-deep) 100%);
  }

  .tank-grid-overlay {
    background-image:
      linear-gradient(rgba(0, 212, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 212, 255, 0.03) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  .tank-hero-gradient {
    background:
      radial-gradient(ellipse 100% 80% at 50% -20%, rgba(0, 212, 255, 0.15) 0%, transparent 60%),
      radial-gradient(ellipse 80% 50% at 80% 50%, rgba(139, 92, 246, 0.1) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 20% 60%, rgba(0, 255, 136, 0.08) 0%, transparent 50%);
  }

  @keyframes tank-data-stream {
    0% {
      background-position: 0% 0%;
    }
    100% {
      background-position: 0% 100%;
    }
  }

  .tank-data-stream {
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(0, 212, 255, 0.03) 25%,
      transparent 50%,
      rgba(0, 255, 136, 0.02) 75%,
      transparent 100%
    );
    background-size: 100% 200%;
    animation: tank-data-stream 20s linear infinite;
  }

  .tank-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    pointer-events: none;
    opacity: 0.5;
  }

  .tank-orb-cyan {
    background: radial-gradient(circle, rgba(0, 212, 255, 0.3) 0%, transparent 70%);
  }

  .tank-orb-purple {
    background: radial-gradient(circle, rgba(139, 92, 246, 0.25) 0%, transparent 70%);
  }

  .tank-orb-green {
    background: radial-gradient(circle, rgba(0, 255, 136, 0.2) 0%, transparent 70%);
  }

  .tank-divider {
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(0, 212, 255, 0.3) 20%,
      rgba(0, 255, 136, 0.3) 50%,
      rgba(0, 212, 255, 0.3) 80%,
      transparent 100%
    );
  }
</style>
