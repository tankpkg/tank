---
import { CopyInstallButton } from '~/components/CopyInstallButton';
import { HeroAuthCta } from '~/components/HeroAuthCta';
import { buttonVariants } from '~/components/ui';
import { GITHUB_ICON_PATH, INSTALL_COMMAND } from '~/consts';
import { cn } from '~/lib/utils';

interface Props {
  skillCount: number;
  starCount: number | null;
}

const { skillCount, starCount } = Astro.props;
---

<section class="tank-hero-gradient tank-data-stream relative overflow-hidden">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 pt-16 pb-16 md:pt-24 md:pb-24">
    <div class="max-w-3xl mx-auto text-center">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-emerald-500/20 bg-emerald-500/5 mb-8">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="w-3.5 h-3.5 text-emerald-400"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round">
          <path
            d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"
          ></path>
        </svg>
        <span class="text-xs font-medium text-emerald-400">
          {skillCount >= 5 ? `${skillCount} Security-Verified Skills · Open Source` : 'Open Source · MIT Licensed'}
        </span>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight mb-6">
        <span class="block">Security-first</span>
        <span class="block text-emerald-400">package manager</span>
        <span class="block mt-2">for AI agent skills</span>
      </h1>

      <p class="text-base sm:text-lg text-muted-foreground mb-8 max-w-2xl mx-auto leading-relaxed">
        Today's skill registries have no versioning, no lockfiles, no permissions, and no security scanning. <span
          class="text-foreground font-medium">Tank is the npm for agent skills</span
        > — with security built in from day one.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/skills"
          class={cn(buttonVariants({ size: 'lg' }), 'bg-emerald-600 hover:bg-emerald-500 text-white group')}
          data-testid="home-primary-cta">
          Browse Skills
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round">
            <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <HeroAuthCta client:load testId="home-secondary-cta" />
      </div>

      <div class="mt-12 flex flex-col items-center gap-4">
        <div
          class="inline-flex items-center gap-2 rounded-lg border border-emerald-500/20 bg-emerald-500/5 px-4 py-2.5">
          <p class="text-xs sm:text-sm text-muted-foreground font-mono">
            <span class="text-emerald-400 select-none">$ </span>
            <span class="text-slate-300">{INSTALL_COMMAND}</span>
          </p>
          <CopyInstallButton client:visible command={INSTALL_COMMAND} />
        </div>
        <a
          href="https://github.com/tankpkg/tank"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 text-sm text-muted-foreground hover:text-emerald-400 transition-colors">
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path fill-rule="evenodd" d={GITHUB_ICON_PATH} clip-rule="evenodd"></path>
          </svg>
          <span>Star on GitHub{starCount !== null ? ` (${starCount})` : ''}</span>
        </a>
      </div>
    </div>
  </div>
</section>
