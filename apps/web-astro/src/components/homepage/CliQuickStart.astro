---
import { cliCommands, INSTALL_COMMAND } from '~/consts';
---

<section class="relative py-16 md:py-24 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-emerald-500/5 to-transparent"></div>

  <div class="container mx-auto px-4 relative">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-8">
        <div
          class="inline-flex items-center justify-center w-12 h-12 rounded-xl bg-emerald-500/10 border border-emerald-500/20 mb-4">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-6 h-6 text-emerald-400"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round">
            <polyline points="4 17 10 11 4 5"></polyline><line x1="12" x2="20" y1="19" y2="19"></line>
          </svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-3">
          Get started in <span class="text-emerald-400">seconds</span>
        </h2>
        <p class="text-muted-foreground">Everything you need, right from the terminal.</p>
      </div>

      <div class="tank-terminal tank-scanlines rounded-xl overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-2.5 border-b border-emerald-500/20 bg-[#0c1222]">
          <span class="size-3 rounded-full bg-red-500/80"></span>
          <span class="size-3 rounded-full bg-amber-500/80"></span>
          <span class="size-3 rounded-full bg-emerald-500/80"></span>
          <span class="ml-3 text-xs text-emerald-400/60 font-mono">tank-cli</span>
        </div>

        <div class="p-4 md:p-6 space-y-4">
          <div class="group">
            <p class="text-xs text-slate-500 mb-1 font-mono"># Install Tank CLI</p>
            <p class="text-sm md:text-base font-mono flex items-center gap-2">
              <span class="text-emerald-400 select-none">$</span>
              <span class="text-slate-200 group-hover:text-white transition-colors">{INSTALL_COMMAND}</span>
            </p>
          </div>
          <div class="border-t border-emerald-500/10"></div>
          {
            cliCommands.map((item) => (
              <div class="group">
                <p class="text-xs text-slate-500 mb-1 font-mono"># {item.desc}</p>
                <p class="text-sm md:text-base font-mono flex items-center gap-2">
                  <span class="text-emerald-400 select-none">$</span>
                  <span class="text-slate-200 group-hover:text-white transition-colors">{item.cmd}</span>
                </p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
