{
  "name": "tank",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "vitest run --config e2e/vitest.config.ts",
    "test:bdd": "bunx bddgen test -c e2e/bdd/playwright.config.ts && bunx playwright test -c e2e/bdd/playwright.config.ts",
    "test:perf": "bun --filter=@internal/web run perf:test",
    "lint": "turbo run lint",
    "format": "biome format --write . && prettier --write '**/*.md' '**/*.feature' '**/*.yaml' '**/*.yml'",
    "check": "biome check .",
    "lint:fix": "biome check --fix .",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@playwright/test": "^1.58.2",
    "@types/bun": "^1.3.10",
    "playwright-bdd": "^8.4.2",
    "prettier": "^3.8.1",
    "prettier-plugin-gherkin": "^3.1.3",
    "tsdown": "^0.21.0",
    "turbo": "^2",
    "typescript": "^5",
    "vitest": "^4"
  },
  "packageManager": "bun@1.3.10",
  "overrides": {
    "ajv": ">=8.18.0",
    "hono": ">=4.12.2",
    "minimatch": ">=10.2.1",
    "esbuild": ">=0.25.0",
    "rollup": ">=4.59.0"
  }
}
