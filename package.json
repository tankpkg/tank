{
  "name": "tank",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "bdd",
    "e2e"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "bun run --filter @internal/e2e test:run",
    "test:e2e:tanstack": "bun run --filter @internal/e2e test:tanstack",
    "test:e2e:all": "bun run --filter @internal/e2e test:all",
    "test:bdd:system": "bun run --filter @internal/bdd test:system",
    "test:bdd:browser": "bun run --filter @internal/bdd test:browser",
    "test:bdd": "bun run test:bdd:system && bun run test:bdd:browser",
    "test:perf": "bun run --filter registry-legacy perf:test",
    "lint": "biome check --write .",
    "lint:readonly": "biome check .",
    "format": "biome format --write . && prettier --write '**/*.md' '**/*.feature' '**/*.yaml' '**/*.yml'",
    "format:readonly": "biome format . && prettier --check '**/*.md' '**/*.feature' '**/*.yaml' '**/*.yml'",
    "typecheck": "tsc -b tsconfig.solution.json --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@tanstack/router-zod-adapter": "^1.81.5",
    "@tsconfig/bun": "^1.0.10",
    "@types/bun": "^1.3.10",
    "postgres": "^3.4.8",
    "prettier": "^3.8.1",
    "prettier-plugin-gherkin": "^3.1.3",
    "registry": "workspace:*",
    "turbo": "^2.8.17",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.10",
  "overrides": {
    "minimatch": "10.2.4",
    "esbuild": "0.27.4",
    "rollup": "4.59.0"
  }
}
