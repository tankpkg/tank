#!/usr/bin/env bash
# Smart pre-push hook: only lint/check projects with staged changes.
# Install: ln -sf ../../scripts/pre-push .git/hooks/pre-push
# Manual:  ./scripts/pre-push
set -euo pipefail

# Determine changed files: diff against the remote tracking branch,
# or against HEAD if no remote is set (first push).
REMOTE_REF=$(git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null || echo "")
if [ -n "$REMOTE_REF" ]; then
  CHANGED=$(git diff --name-only "$REMOTE_REF"...HEAD 2>/dev/null || git diff --name-only HEAD~1)
else
  # First push — check all files in last commit
  CHANGED=$(git diff --name-only HEAD~1 2>/dev/null || git diff --name-only --cached)
fi

if [ -z "$CHANGED" ]; then
  echo "pre-push: no changed files detected, skipping."
  exit 0
fi

FAILED=0

# ── Python scanner ──────────────────────────────────────────────────
if echo "$CHANGED" | grep -q "^apps/python-api/"; then
  echo "▸ apps/python-api changed — running Python checks"
  export UV_CACHE_DIR="${UV_CACHE_DIR:-/tmp/tank-uv-cache}"

  echo "  ├─ ruff check"
  if ! uvx ruff check --config apps/python-api/pyproject.toml apps/python-api/; then
    echo "  │  ✗ ruff check failed"
    FAILED=1
  else
    echo "  │  ✓ ruff check passed"
  fi

  echo "  ├─ ruff format --check"
  if ! uvx ruff format --check --config apps/python-api/pyproject.toml apps/python-api/ > /dev/null 2>&1; then
    echo "  │  ✗ ruff format check failed (run: just fmt python)"
    FAILED=1
  else
    echo "  │  ✓ ruff format passed"
  fi

  echo "  └─ pytest"
  if ! (cd apps/python-api && PYTHONPATH=. uv run pytest lib/scan/test_snyk_scanner.py lib/scan/test_llm_analyzer.py -q 2>/dev/null); then
    echo "     ✗ pytest failed"
    FAILED=1
  else
    echo "     ✓ pytest passed"
  fi
fi

# ── TypeScript packages (cli, registry, mcp-server, internals) ──────
TS_PACKAGES=(
  "packages/cli"
  "apps/registry"
  "packages/mcp-server"
  "packages/internals-schemas"
  "packages/internals-helpers"
  "bdd"
  "e2e"
)
TS_CHANGED=0
for pkg in "${TS_PACKAGES[@]}"; do
  if echo "$CHANGED" | grep -q "^${pkg}/"; then
    TS_CHANGED=1
    break
  fi
done

if [ "$TS_CHANGED" -eq 1 ]; then
  echo "▸ TypeScript packages changed — running JS/TS checks"

  echo "  ├─ lint check"
  if ! bun run lint:readonly > /dev/null 2>&1; then
    echo "  │  ✗ lint failed (run: just lint)"
    FAILED=1
  else
    echo "  │  ✓ lint passed"
  fi

  echo "  ├─ format check"
  if ! bun run format:readonly > /dev/null 2>&1; then
    echo "  │  ✗ format check failed (run: just fmt)"
    FAILED=1
  else
    echo "  │  ✓ format passed"
  fi

  echo "  └─ typecheck"
  if ! bun tsc -b --noEmit > /dev/null 2>&1; then
    echo "     ✗ typecheck failed"
    FAILED=1
  else
    echo "     ✓ typecheck passed"
  fi
fi

# ── Root config / CI changes ────────────────────────────────────────
if echo "$CHANGED" | grep -qE "^(\.github/|eslint\.config\.ts|\.prettierrc|\.prettierignore|tsconfig|package\.json|justfile)"; then
  echo "▸ Root config changed — running full verification"

  if ! bun prettier --check . > /dev/null 2>&1; then
    echo "  ✗ prettier format check failed"
    FAILED=1
  fi
fi

# ── Result ──────────────────────────────────────────────────────────
echo ""
if [ "$FAILED" -ne 0 ]; then
  echo "✗ Pre-push checks failed. Fix issues above before pushing."
  echo "  Bypass with: git push --no-verify"
  exit 1
else
  echo "✓ All pre-push checks passed."
  exit 0
fi
